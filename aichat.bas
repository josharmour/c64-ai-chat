10 REM *** COMMODORE 64 AI CHAT ***
20 REM SWIFTLINK ACIA AT $DE00
30 BA=56832
40 PRINT CHR$(147);"COMMODORE 64 AI CHAT"
50 PRINT
60 INPUT "SERVER:PORT";S$
70 IF S$="" THEN S$="10.0.0.10:6464"
80 PRINT:PRINT "CONNECTING TO ";S$;"..."
90 POKE BA+1,0:POKE BA+3,0:POKE BA+2,11
100 A$="ATDT"+S$+CHR$(13)
110 FOR I=1 TO LEN(A$):POKE BA,ASC(MID$(A$,I,1)):FOR D=1 TO 5:NEXT D:NEXT I
120 PRINT "F1 TO QUIT.":PRINT
125 POKE 204,0
130 S=PEEK(BA+1):IF(S AND 8)THEN PRINT CHR$(PEEK(BA));
140 GET B$:IF B$="" THEN 130
150 IF B$=CHR$(133) THEN 200
160 POKE BA,ASC(B$):GOTO 130
200 PRINT:PRINT "DISCONNECTED."
210 END
